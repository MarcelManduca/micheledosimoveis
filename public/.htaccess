# Cache headers for LiteSpeed / Apache (Hostinger).
# Static assets are served directly by the web server, bypassing the Node process,
# so cache-control MUST be set here — not only in src/server.ts.

<IfModule mod_headers.c>
  # Versioned build assets — immutable, 1 year.
  <FilesMatch "\.(js|mjs|css|map|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Fingerprinted images produced by Vite in /assets/ — immutable, 1 year.
  <FilesMatch "\.(webp|avif|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML must NOT be cached long — SSR content changes.
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# Fallback for LiteSpeed / older Apache without mod_headers
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/javascript             "access plus 1 year"
  ExpiresByType text/javascript                    "access plus 1 year"
  ExpiresByType text/css                           "access plus 1 year"
  ExpiresByType image/webp                         "access plus 1 year"
  ExpiresByType image/avif                         "access plus 1 year"
  ExpiresByType image/png                          "access plus 1 year"
  ExpiresByType image/jpeg                         "access plus 1 year"
  ExpiresByType image/svg+xml                      "access plus 1 year"
  ExpiresByType image/x-icon                       "access plus 1 year"
  ExpiresByType font/woff2                         "access plus 1 year"
  ExpiresByType font/woff                          "access plus 1 year"
  ExpiresByType text/html                          "access plus 0 seconds"
</IfModule>

# GZIP / Brotli — LiteSpeed applies automatically, but declare fallback.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript text/javascript text/css text/html application/json image/svg+xml
</IfModule>
